rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // ── DEVELOPMENT: allow all reads and writes ──────────────
    // WARNING: Remove this before going to production!
    match /{allPaths=**} {
      allow read, write: if true;
    }

    // ── PRODUCTION (commented out — uncomment when auth is added) ──
    // match /books/{allPaths=**} {
    //   allow read: if true;               // public can read books
    //   allow write: if request.auth != null;  // only logged-in users can write
    // }
  }
}
